# GitHub Personal Access Token (required for repoExplainer GitHub API calls)
GITHUB_TOKEN=Token

# Ollama base URL (default: http://localhost:11434, overridden in K8s via ConfigMap)
OLLAMA_BASE_URL=http://localhost:11434

# Service ports (defaults match application.yml configs)
# SERVER_PORT_MCP_GIT=8081
# SERVER_PORT_SQLMCP=8082
# SERVER_PORT_FILE_READER=8083
# SERVER_PORT_REPO_EXPLAINER=8084
